generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EmploymentType {
  FULL_TIME
  CONTRACT
  INTERN
  CONSULTANT
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  RESIGNED
  TERMINATED
  PROBATION
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  COMPASSIONATE
  UNPAID
  STUDY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
  ARCHIVED
}

enum ApplicantStatus {
  NEW
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  OFFERED
  HIRED
  REJECTED
}

enum InterviewType {
  PHONE
  VIRTUAL
  PHYSICAL
  TECHNICAL
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum UserRole {
  SUPER_ADMIN
  HR_MANAGER
  DEPARTMENT_HEAD
  FINANCE_OFFICER
  EMPLOYEE
  SALES_MANAGER
  SALES_AGENT
}

// ─── Sales Module Enums ───────────────────────────────────────────────────────

enum LeadSource {
  WEBSITE
  REFERRAL
  EMPLOYEE
  SOCIAL_MEDIA
  COLD_CALL
  EMAIL
  WALK_IN
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  NEEDS_QUOTATION
  QUOTATION_SENT
  NEGOTIATION
  WON
  LOST
  FUTURE_PROSPECT
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  NOTE
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  APPROVED
  REJECTED
  EXPIRED
}

enum ClientCategory {
  CORPORATE
  SME
  INDIVIDUAL
}

enum ServiceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum SalesTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum SalesTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  password    String
  rawPassword String?   // admin-set plain text — cleared when user self-changes
  role        UserRole  @default(EMPLOYEE)
  isActive    Boolean   @default(true)
  employeeId  String?   @unique
  employee    Employee? @relation(fields: [employeeId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sessions    Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Department {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  headId      String?
  head        Employee?  @relation("DepartmentHead", fields: [headId], references: [id])
  employees   Employee[] @relation("DepartmentEmployees")
  jobs        Job[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Employee {
  id               String              @id @default(cuid())
  employeeCode     String              @unique
  firstName        String
  lastName         String
  email            String              @unique
  personalEmail    String?
  phone            String
  nationalId       String?
  dateOfBirth      DateTime?
  gender           String?
  address          String?
  city             String?
  country          String              @default("Kenya")
  profilePhoto     String?
  departmentId     String?
  department       Department?         @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  jobTitle         String
  employmentType   EmploymentType      @default(FULL_TIME)
  employmentStatus EmploymentStatus    @default(ACTIVE)
  dateHired        DateTime
  probationEndDate DateTime?
  basicSalary      Float?
  bankName         String?
  bankBranch       String?
  bankCode         String?
  bankAccount      String?
  mpesaPhone       String?
  kraPin           String?
  managerId        String?
  manager          Employee?           @relation("Reports", fields: [managerId], references: [id])
  directReports    Employee[]          @relation("Reports")
  contractUrl      String?
  ndaUrl           String?
  idFrontUrl       String?
  idBackUrl        String?
  passportPhotoUrl String?
  kraPinUrl        String?
  nhifCardUrl      String?
  nssfCardUrl      String?
  employmentContract EmploymentContract?
  emergencyContact String?
  emergencyPhone   String?
  user             User?
  departmentHead   Department[]        @relation("DepartmentHead")
  attendances      Attendance[]
  leaves           Leave[]
  approvedLeaves   Leave[]             @relation("LeaveApprover")
  payrolls         Payroll[]
  reviewsGiven     PerformanceReview[] @relation("Reviewer")
  reviewsReceived  PerformanceReview[] @relation("Reviewee")
  goals            Goal[]
  announcements    Announcement[]
  auditLogs        AuditLog[]
  leaveBalances    LeaveBalance[]
  // Sales relations
  leadsAssigned    Lead[]              @relation("LeadAssignee")
  leadsCreated     Lead[]              @relation("LeadCreator")
  leadActivities   LeadActivity[]
  quotationsCreated Quotation[]
  clientsCreated   Client[]            @relation("ClientCreator")
  clientsAssigned  Client[]            @relation("ClientAssignee")
  salesTasksAssigned SalesTask[]       @relation("SalesTaskAssignee")
  salesTasksCreated  SalesTask[]       @relation("SalesTaskCreator")
  // Recruitment relations
  jobsManaged            Job[]                 @relation("JobHiringManager")
  interviewsConducted    Interview[]           @relation("InterviewConductor")
  interviewEvaluations   InterviewEvaluation[]
  jobOffersCreated       JobOffer[]            @relation("OfferCreatedBy")
  recruitmentNotes       RecruitmentNote[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model Attendance {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  clockIn    DateTime
  clockOut   DateTime?
  totalHours Float?
  status     String    @default("PRESENT")
  notes      String?
  ipAddress  String?
  location   String?
  date       DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Leave {
  id         String      @id @default(cuid())
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id])
  leaveType  LeaveType
  startDate  DateTime
  endDate    DateTime
  days       Int
  reason     String?
  status     LeaveStatus @default(PENDING)
  approvedBy String?
  approver   Employee?   @relation("LeaveApprover", fields: [approvedBy], references: [id])
  approvedAt DateTime?
  comments   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model LeaveBalance {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  leaveType  LeaveType
  year       Int
  allocated  Int
  used       Int       @default(0)
  pending    Int       @default(0)
  remaining  Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([employeeId, leaveType, year])
}

model Payroll {
  id              String    @id @default(cuid())
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id])
  month           Int
  year            Int
  basicSalary     Float
  allowances      Float     @default(0)
  overtime        Float     @default(0)
  bonuses         Float     @default(0)
  grossSalary     Float
  paye            Float     @default(0)
  nhif            Float     @default(0)
  nssf            Float     @default(0)
  otherDeductions Float     @default(0)
  netSalary       Float
  status          String    @default("DRAFT")
  paymentDate     DateTime?
  paymentRef      String?
  generatedAt     DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([employeeId, month, year])
}

model Job {
  id               String      @id @default(cuid())
  title            String
  slug             String?     @unique
  description      String
  requirements     String?
  responsibilities String?
  departmentId     String?
  department       Department? @relation(fields: [departmentId], references: [id])
  type             String      @default("Full-time")
  location         String?
  salaryMin        Float?
  salaryMax        Float?
  positions        Int         @default(1)
  skills           String[]
  experienceLevel  String?
  educationReq     String?
  benefits         String?
  hiringManagerId  String?
  hiringManager    Employee?   @relation("JobHiringManager", fields: [hiringManagerId], references: [id])
  status           JobStatus   @default(OPEN)
  postedAt         DateTime?
  deadline         DateTime?
  applicants       Applicant[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Applicant {
  id              String          @id @default(cuid())
  jobId           String
  job             Job             @relation(fields: [jobId], references: [id])
  firstName       String
  lastName        String
  email           String
  phone           String?
  resumeUrl       String?
  coverLetter     String?
  linkedIn        String?
  portfolio       String?
  expectedSalary  Float?
  availableFrom   DateTime?
  experienceYears Int?
  currentCompany  String?
  educationLevel  String?
  skills          String[]
  source          String?         @default("DIRECT")
  talentPool      String?
  status          ApplicantStatus @default(NEW)
  score           Int?
  notes           String?
  interviewDate   DateTime?
  interviews      Interview[]
  offer           JobOffer?
  notesList       RecruitmentNote[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Interview {
  id            String          @id @default(cuid())
  applicantId   String
  applicant     Applicant       @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  type          InterviewType   @default(PHYSICAL)
  scheduledAt   DateTime
  location      String?
  meetingLink   String?
  interviewerId String?
  interviewer   Employee?       @relation("InterviewConductor", fields: [interviewerId], references: [id])
  status        InterviewStatus @default(SCHEDULED)
  notes         String?
  evaluation    InterviewEvaluation?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model InterviewEvaluation {
  id             String    @id @default(cuid())
  interviewId    String    @unique
  interview      Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  technical      Int?
  communication  Int?
  problemSolving Int?
  culturalFit    Int?
  overallScore   Int?
  recommendation String?
  notes          String?
  evaluatedById  String?
  evaluatedBy    Employee? @relation(fields: [evaluatedById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model JobOffer {
  id              String      @id @default(cuid())
  applicantId     String      @unique
  applicant       Applicant   @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  salary          Float
  startDate       DateTime?
  probationPeriod Int?
  terms           String?
  status          OfferStatus @default(PENDING)
  sentAt          DateTime?
  respondedAt     DateTime?
  notes           String?
  createdById     String?
  createdBy       Employee?   @relation("OfferCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model RecruitmentNote {
  id          String    @id @default(cuid())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  content     String
  authorId    String?
  author      Employee? @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now())
}

model PerformanceReview {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation("Reviewee", fields: [employeeId], references: [id])
  reviewerId   String
  reviewer     Employee @relation("Reviewer", fields: [reviewerId], references: [id])
  period       String
  rating       Int
  comments     String?
  goals        String?
  strengths    String?
  improvements String?
  status       String   @default("DRAFT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Goal {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  title       String
  description String?
  targetDate  DateTime
  progress    Int      @default(0)
  status      String   @default("ACTIVE")
  period      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Announcement {
  id           String    @id @default(cuid())
  title        String
  content      String
  type         String    @default("GENERAL")
  priority     String    @default("NORMAL")
  departmentId String?
  authorId     String
  author       Employee  @relation(fields: [authorId], references: [id])
  publishedAt  DateTime  @default(now())
  expiresAt    DateTime?
  readBy       String[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AuditLog {
  id         String    @id @default(cuid())
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  action     String
  entity     String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
}

model CompanySettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Sales Module Models ──────────────────────────────────────────────────────

model Lead {
  id                  String         @id @default(cuid())
  leadNumber          String         @unique
  companyName         String?
  contactPerson       String
  phone               String?
  whatsapp            String?
  email               String?
  location            String?
  industry            String?
  source              LeadSource     @default(WEBSITE)
  services            String[]
  priority            LeadPriority   @default(MEDIUM)
  status              LeadStatus     @default(NEW)
  notes               String?
  expectedValue       Float?
  expectedCloseDate   DateTime?
  lostReason          String?
  assignedToId        String?
  assignedTo          Employee?      @relation("LeadAssignee", fields: [assignedToId], references: [id])
  createdById         String?
  createdBy           Employee?      @relation("LeadCreator", fields: [createdById], references: [id])
  convertedToClientId String?
  convertedToClient   Client?        @relation("LeadConversion", fields: [convertedToClientId], references: [id])
  activities          LeadActivity[]
  quotations          Quotation[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model LeadActivity {
  id            String       @id @default(cuid())
  leadId        String
  lead          Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type          ActivityType
  subject       String
  notes         String?
  performedById String?
  performedBy   Employee?    @relation(fields: [performedById], references: [id])
  activityDate  DateTime     @default(now())
  createdAt     DateTime     @default(now())
}

model ServiceCatalog {
  id             String          @id @default(cuid())
  name           String
  description    String?
  category       String
  basePrice      Float?
  packages       Json?
  isActive       Boolean         @default(true)
  quotationItems QuotationItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Quotation {
  id               String          @id @default(cuid())
  quotationNumber  String          @unique
  leadId           String?
  lead             Lead?           @relation(fields: [leadId], references: [id])
  clientId         String?
  client           Client?         @relation(fields: [clientId], references: [id])
  clientName       String
  clientEmail      String?
  status           QuotationStatus @default(DRAFT)
  subtotal         Float           @default(0)
  taxRate          Float           @default(16)
  taxAmount        Float           @default(0)
  discountAmount   Float           @default(0)
  totalAmount      Float           @default(0)
  validUntil       DateTime?
  deliveryTimeline String?
  projectScope     String?
  terms            String?
  notes            String?
  sentAt           DateTime?
  viewedAt         DateTime?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?
  createdById      String?
  createdBy        Employee?       @relation(fields: [createdById], references: [id])
  items            QuotationItem[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model QuotationItem {
  id          String          @id @default(cuid())
  quotationId String
  quotation   Quotation       @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  serviceId   String?
  service     ServiceCatalog? @relation(fields: [serviceId], references: [id])
  name        String
  description String?
  quantity    Int             @default(1)
  unitPrice   Float
  totalPrice  Float
  createdAt   DateTime        @default(now())
}

model Client {
  id            String          @id @default(cuid())
  clientNumber  String          @unique
  companyName   String
  contactPerson String
  phone         String?
  whatsapp      String?
  email         String?
  address       String?
  city          String?
  country       String          @default("Kenya")
  industry      String?
  category      ClientCategory  @default(CORPORATE)
  tags          String[]
  website       String?
  notes         String?
  isActive      Boolean         @default(true)
  createdById   String?
  createdBy     Employee?       @relation("ClientCreator", fields: [createdById], references: [id])
  assignedToId  String?
  assignedTo    Employee?       @relation("ClientAssignee", fields: [assignedToId], references: [id])
  leads         Lead[]          @relation("LeadConversion")
  quotations    Quotation[]
  services      ClientService[]
  subscriptions Subscription[]
  tasks         SalesTask[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model ClientService {
  id             String        @id @default(cuid())
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  serviceName    String
  description    String?
  assignedTeam   String?
  startDate      DateTime?
  completionDate DateTime?
  status         ServiceStatus @default(PENDING)
  attachments    String[]
  notes          String?
  tasks          SalesTask[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Subscription {
  id            String             @id @default(cuid())
  clientId      String
  client        Client             @relation(fields: [clientId], references: [id])
  serviceName   String
  description   String?
  startDate     DateTime
  expiryDate    DateTime
  renewalPrice  Float
  billingCycle  BillingCycle       @default(YEARLY)
  status        SubscriptionStatus @default(ACTIVE)
  autoRenew     Boolean            @default(false)
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model SalesTask {
  id              String            @id @default(cuid())
  title           String
  description     String?
  clientId        String?
  client          Client?           @relation(fields: [clientId], references: [id])
  clientServiceId String?
  clientService   ClientService?    @relation(fields: [clientServiceId], references: [id])
  assignedToId    String?
  assignedTo      Employee?         @relation("SalesTaskAssignee", fields: [assignedToId], references: [id])
  createdById     String?
  createdBy       Employee?         @relation("SalesTaskCreator", fields: [createdById], references: [id])
  deadline        DateTime?
  priority        SalesTaskPriority @default(MEDIUM)
  status          SalesTaskStatus   @default(TODO)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Portfolio {
  id            String    @id @default(cuid())
  clientName    String
  industry      String?
  serviceType   String
  description   String?
  projectImages String[]
  completedAt   DateTime?
  testimonial   String?
  caseStudy     String?
  isPublished   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model EmploymentContract {
  id           String    @id @default(cuid())
  employeeId   String    @unique
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  token        String    @unique @default(cuid())
  contractHtml String    @db.Text
  sentAt       DateTime?
  signedAt     DateTime?
  signedByName String?
  signedByIp   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
